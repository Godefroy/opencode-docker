# ============================================================================
# opencode-docker — copy to .env and fill in.   cp .env.example .env
# ============================================================================

# ---- Web access: opencode web + code-server --------------------------------
# ONE login/password protects BOTH the opencode web UI and the code-server
# (VS Code in the browser) editor. LEAVE PASSWORD EMPTY = no auth (local only!).
WEB_USERNAME=opencode
WEB_PASSWORD=change-me

OPENCODE_PORT=4096
CODE_SERVER_PORT=4097

# ---- Claude provider -------------------------------------------------------
# CLAUDE_AUTH_MODE:
#   max     -> use your Claude Max subscription via the opencode-with-claude
#              plugin (default).
#   manual  -> don't touch opencode config; pick your provider/model yourself
#              in the opencode web UI (/connect). Works for API keys, other
#              providers, etc. Your choice is saved in the home volume.
CLAUDE_AUTH_MODE=max

# Claude Max auth for `max` mode. RECOMMENDED: generate a long-lived token ONCE on a
# machine that has Claude + a browser (e.g. your laptop):
#   claude setup-token        # authorize in the browser -> prints an sk-ant-oat01-... token
# Paste that full sk-ant-oat01-... value below. Every box + every recreate is then
# authenticated at boot (no interactive login).
# Leave empty to instead log in interactively per box (make claude-login).
CLAUDE_CODE_OAUTH_TOKEN=

# ---- GitHub / git ----------------------------------------------------------
# Personal Access Token — used for `git` over HTTPS and the `gh` CLI.
GITHUB_PAT=
# Left empty, these are auto-derived from the PAT (GitHub /user API: name/login,
# public email or the GitHub noreply address). Set them to override.
GIT_USER_NAME=
GIT_USER_EMAIL=

# ---- Docker-in-Docker ------------------------------------------------------
# true  -> start an isolated Docker daemon inside the box (default)
# false -> expects /var/run/docker.sock to be mounted (host daemon; no isolation)
ENABLE_DIND=true

# ---- Advanced --------------------------------------------------------------
# Regenerate opencode.json from these env vars on every boot (overwrites edits).
OPENCODE_FORCE_CONFIG=false
